#cloud-config
# NoCloud seed for the clevis-encryption NBDE VM smoke test.
# run.sh substitutes __SSH_PUBKEY__ before building the seed ISO.
#
# This file does ONLY platform prep that is out of the role's scope: grant the
# control host SSH access and refresh the apt cache. The clevis-encryption role
# (NBDE) installs its own packages (clevis, cryptsetup) afterwards over SSH via
# manual_test/playbook.yml, which is the actual thing under test. No ZFS/DKMS
# build is needed — this role is NBDE-only; storage assembly is a separate
# consumer role's concern.
hostname: clevis-vm
ssh_pwauth: false
users:
  - name: debian
    groups: [sudo]
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    shell: /bin/bash
    ssh_authorized_keys:
      - __SSH_PUBKEY__
package_update: true
runcmd:
  - [ bash, -lc, "set -x;
      export DEBIAN_FRONTEND=noninteractive;
      apt-get update;
      echo '=== VM-PREP-DONE ==='" ]
