#!/bin/bash
# Managed by Ansible role: clevis_encryption — https://github.com/KvalitetsIT/clevis-encryption-role
# Do not edit by hand; regenerated on each role run.
#
# Viability gate for encrypted-storage-ready.target.  Exit 0 if the ZFS pool is
# imported and usable (health ONLINE or DEGRADED — a degraded mirror still
# serves I/O); exit 1 if the pool is absent / FAULTED / UNAVAIL so the barrier
# is NOT reached and the Proxmox daemons stay stopped for manual recovery.
set -uo pipefail
export PATH=/usr/sbin:/usr/bin:/sbin:/bin

pool="{{ clevis_pool_name }}"
health=$(zpool list -H -o health "$pool" 2>/dev/null | head -n1 | tr -d '[:space:]')

echo "encrypted-storage-pool-check: pool=$pool health=${health:-absent}"

case "$health" in
  ONLINE|DEGRADED) exit 0 ;;
  *)               exit 1 ;;
esac
